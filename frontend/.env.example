# Auth
# Google OAuth client ID exposed to the browser for Google sign-in.
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
# Google Identity Services script URL loaded by the auth page.
VITE_GOOGLE_IDENTITY_SCRIPT_URL=https://accounts.google.com/gsi/client

# App Config
# Browser-facing API base URL used by Axios.
VITE_API_BASE_URL=/
# Backend target used by the Vite development proxy.
VITE_API_PROXY_TARGET=http://localhost:5000
# Axios request timeout in milliseconds.
VITE_API_TIMEOUT_MS=10000
# Host used by the local Vite dev server.
VITE_DEV_HOST=0.0.0.0
# Port used by the local Vite dev server.
VITE_DEV_PORT=3000

# Auth
# Google OAuth client ID exposed to the browser for Google sign-in.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
# Google Identity Services script URL loaded by the auth page.
NEXT_PUBLIC_GOOGLE_IDENTITY_SCRIPT_URL=https://accounts.google.com/gsi/client

# App Config
# Browser-facing API base URL used by Axios.
NEXT_PUBLIC_API_BASE_URL=/
# Backend target used by the Vite development proxy.
API_PROXY_TARGET=http://localhost:5000
# Axios request timeout in milliseconds.
NEXT_PUBLIC_API_TIMEOUT_MS=10000
# Optional port used by the local Next.js dev server.
PORT=3002

# Database
# PostgreSQL connection string used by Drizzle and the Fastify backend.
DATABASE_URL=postgresql://your_db_user:your_db_password@your-service.com:5432/your_db_name?sslmode=require
# Upstash Redis REST URL used for caching and JWT revocation checks.
UPSTASH_REDIS_REST_URL=https://your-service.com
# Upstash Redis REST token used to authenticate Redis requests.
UPSTASH_REDIS_REST_TOKEN=your_secret_key_here

# Auth
# JWT signing secret for access and refresh tokens.
JWT_SECRET=your_secret_key_here_change_me_123456
# Google OAuth client ID used by the backend to validate Google credentials.
GOOGLE_CLIENT_ID=your_google_client_id_here
# Google token info endpoint used to verify Google ID tokens.
GOOGLE_TOKENINFO_URL=https://oauth2.googleapis.com/tokeninfo
# Generic Google Apps Script webhook URL used to send auth emails.
GAS_EMAIL_DISPATCH_URL=https://script.google.com/macros/s/your-script-id/exec
# Shared secret your backend sends to Apps Script so only your server can trigger email sends.
GAS_EMAIL_DISPATCH_TOKEN=replace_with_a_long_random_secret
# Optional dedicated Apps Script endpoint for verification emails.
GAS_EMAIL_VERIFY_URL=
# Optional dedicated Apps Script endpoint for password reset emails.
GAS_PASSWORD_RESET_URL=
# Legacy magic-link endpoint. Leave blank when using the full auth flow above.
GAS_MAGIC_LINK_URL=

# External APIs
# Gemini model identifiers.
GEMINI_MODEL_1=gemini-3.1-flash-lite
GEMINI_MODEL_2=gemini-3.1-flash-lite
GEMINI_MODEL_3=gemini-3.1-flash-lite
GEMINI_MODEL_FALLBACK=gemini-3.1-flash-lite

# Gemini API keys — dedicated feature keys.
GEMINI_PRECHECK_API_KEY=
GEMINI_SHADOW_RESUME_KEY=
GEMINI_PORTFOLIO_KEY=

GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=
GEMINI_KEY_FALLBACK=

# Adzuna jobs API base URL.
ADZUNA_API_BASE_URL=https://api.adzuna.com/v1/api/jobs/in/search/1
# The Muse jobs API base URL.
MUSE_API_BASE_URL=https://www.themuse.com/api/public/v2/jobs
# The Muse API key.
MUSE_API_KEY=
# Reed jobs API base URL.
REED_API_BASE_URL=https://www.reed.co.uk/api/1.0/search
# Reed API key.
REED_API_KEY=
# Adzuna application ID.
ADZUNA_APP_ID=
# Adzuna application key.
ADZUNA_APP_KEY=
# Adzuna pooled credentials.
ADZUNA_APP_ID1=
ADZUNA_APP_ID2=
ADZUNA_APP_ID3=
ADZUNA_APP_ID4=
ADZUNA_APP_ID5=
ADZUNA_APP_KEY1=
ADZUNA_APP_KEY2=
ADZUNA_APP_KEY3=
ADZUNA_APP_KEY4=
ADZUNA_APP_KEY5=
# Remotive jobs API base URL.
REMOTIVE_API_BASE_URL=https://remotive.com/api/remote-jobs
# JSearch API base URL.
JSEARCH_API_BASE_URL=https://jsearch.p.rapidapi.com/search
# JSearch API host header value for RapidAPI.
JSEARCH_API_HOST=jsearch.p.rapidapi.com
# JSearch API key.
JSEARCH_API_KEY=
JSEARCH_RAPIDAPI_KEY=
JSEARCH_API_KEY1=
JSEARCH_API_KEY2=
JSEARCH_API_KEY3=
JSEARCH_API_KEY4=
JSEARCH_API_KEY5=
# Jooble jobs API base URL and pooled API keys.
JOOBLE_API_BASE_URL=https://jooble.org/api
JOOBLE_API_KEY1=
JOOBLE_API_KEY2=
JOOBLE_API_KEY3=
# Serper search API URL.
SERPER_API_URL=https://google.serper.dev/search
# Serper API key.
SERPER_API_KEY=
SERPER_API_KEY1=
SERPER_API_KEY2=
SERPER_API_KEY3=
SERPER_API_KEY4=
SERPER_API_KEY5=
# DuckDuckGo HTML fallback endpoint used when primary job providers fail.
DUCKDUCKGO_HTML_URL=https://html.duckduckgo.com/html/

# App Config
# Runtime environment for the backend server.
NODE_ENV=development
# Network host bound by the Fastify server.
HOST=0.0.0.0
# Port used by the Fastify backend.
PORT=5000
# Browser origin allowed to call the backend.
FRONTEND_URL=http://localhost:3000

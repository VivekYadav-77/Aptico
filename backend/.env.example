# Database
# PostgreSQL connection string used by Drizzle and the Fastify backend.
DATABASE_URL=postgresql://your_db_user:your_db_password@your-service.com:5432/your_db_name?sslmode=require
# Upstash Redis REST URL used for caching and JWT revocation checks.
UPSTASH_REDIS_REST_URL=https://your-service.com
# Upstash Redis REST token used to authenticate Redis requests.
UPSTASH_REDIS_REST_TOKEN=your_secret_key_here

# Auth
# JWT signing secret for access and refresh tokens.
JWT_SECRET=your_secret_key_here_change_me_123456
# Google OAuth client ID used by the backend to validate Google credentials.
GOOGLE_CLIENT_ID=your_google_client_id_here
# Google token info endpoint used to verify Google ID tokens.
GOOGLE_TOKENINFO_URL=https://oauth2.googleapis.com/tokeninfo
# Google Apps Script webhook URL used to send magic-link emails.
GAS_MAGIC_LINK_URL=https://your-service.com/send-magic-link

# External APIs
# Gemini model name used for resume analysis and apply-kit generation.
GEMINI_MODEL=gemini-2.0-flash-lite
# Primary Gemini API key.
GEMINI_KEY_1=your_secret_key_here
# Secondary Gemini API key for rotation and fallback.
GEMINI_KEY_2=your_secret_key_here
# Tertiary Gemini API key for rotation and fallback.
GEMINI_KEY_3=your_secret_key_here
# Adzuna jobs API base URL.
ADZUNA_API_BASE_URL=https://api.adzuna.com/v1/api/jobs/in/search/1
# Adzuna application ID.
ADZUNA_APP_ID=your_adzuna_app_id_here
# Adzuna application key.
ADZUNA_APP_KEY=your_secret_key_here
# Remotive jobs API base URL.
REMOTIVE_API_BASE_URL=https://remotive.com/api/remote-jobs
# JSearch API base URL.
JSEARCH_API_BASE_URL=https://your-service.com/search
# JSearch API host header value for RapidAPI.
JSEARCH_API_HOST=your_jsearch_host_here
# JSearch API key.
JSEARCH_API_KEY=your_secret_key_here
# Serper search API URL.
SERPER_API_URL=https://your-service.com/search
# Serper API key.
SERPER_API_KEY=your_secret_key_here
# DuckDuckGo HTML fallback endpoint used when primary job providers fail.
DUCKDUCKGO_HTML_URL=https://html.duckduckgo.com/html/

# App Config
# Runtime environment for the backend server.
NODE_ENV=development
# Network host bound by the Fastify server.
HOST=0.0.0.0
# Port used by the Fastify backend.
PORT=5000
# Browser origin allowed to call the backend.
FRONTEND_URL=http://localhost:3000
